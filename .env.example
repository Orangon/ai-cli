# Required: your API key
OPENAI_API_KEY_CLI=your-api-key-here

# Optional: custom base URL for any OpenAI-compatible API (defaults to OpenAI official)
# OPENAI_BASE_URL_CLI=https://your-custom-endpoint/v1

# Optional: model name to use (defaults to deepseek-v4-flash)
# OPENAI_MODEL_CLI=deepseek-v4-flash

# Note: You can also configure these via the interactive wizard:
#   $ ai --config
# Config is stored in ~/.ai-cli/.env
